# ============================================
# RENOMAG — Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Base de données ---
# DATABASE_URL: Connection pooler (port 6543) pour Vercel serverless
# Format Supabase pooler: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# DIRECT_URL: Connexion directe (port 5432) pour les migrations
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service (server-side uniquement, jamais exposée au client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate Limiting (Upstash Redis) ---
# Optionnel en dev (fallback memory store)
# Requis en production (multi-instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Application ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dashboard privé ---
# Mot de passe d'accès au dashboard privé (/dashboard-prive)
DASHBOARD_PASSWORD=change-me-in-production

# --- Sentry (optionnel) ---
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
