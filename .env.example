# ============================================
# RENOMAG — Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Base de données ---
# URL PostgreSQL (Supabase ou autre)
# Format : postgresql://user:password@host:port/database
DATABASE_URL=

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service (server-side uniquement, jamais exposée au client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate Limiting (Upstash Redis) ---
# Optionnel en dev (fallback memory store)
# Requis en production (multi-instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Application ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
