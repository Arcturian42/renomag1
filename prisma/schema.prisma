generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ARTISAN
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  REJECTED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProjectStatus {
  QUOTE_REQUESTED
  QUOTES_RECEIVED
  QUOTE_ACCEPTED
  WORK_SCHEDULED
  IN_PROGRESS
  COMPLETED
  REVIEWED
  CANCELLED
}

enum DocumentType {
  DPE
  DEVIS
  CONTRAT
  FACTURE
  PHOTO_AVANT
  PHOTO_APRES
  CERTIFICATION
  OTHER
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  role          Role            @default(USER)
  status        String          @default("active")
  source        String          @default("Direct")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  profile       Profile?
  artisan       ArtisanCompany?
  messagesSent  Message[]       @relation("SentMessages")
  messagesReceived Message[]    @relation("ReceivedMessages")
  notifications Notification[]
  reviews       Review[]
  projects      Project[]
  payments      Payment[]
  favorites     Favorite[]
  documents     Document[]
  auditLogs     AuditLog[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  firstName String?
  lastName  String?
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  user      User     @relation(fields: [userId], references: [id])
}

model ArtisanCompany {
  id              String          @id @default(uuid())
  userId          String          @unique
  slug            String          @unique
  name            String
  siret           String          @unique
  description     String?
  address         String
  city            String
  zipCode         String
  department      String
  region          String?
  latitude        Float?
  longitude       Float?
  phone           String?
  email           String?
  website         String?
  avatar          String?
  logoUrl         String?
  isFeatured      Boolean         @default(false)
  verified        Boolean         @default(false)
  premium         Boolean         @default(false)
  available       Boolean         @default(true)
  rating          Float           @default(0)
  reviewCount     Int             @default(0)
  projectCount    Int             @default(0)
  yearsExperience Int             @default(0)
  responseTime    String?
  since           Int?
  gallery         Json?
  user            User            @relation(fields: [userId], references: [id])
  certifications  Certification[]
  specialties     Specialty[]
  leads           Lead[]
  reviews         Review[]
  subscription    Subscription?
  quotes          Quote[]
  projects        Project[]
  contactAttempts ContactAttempt[]
  favorites       Favorite[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([city])
  @@index([department])
  @@index([region])
  @@index([rating])
  @@index([isFeatured])
  @@index([verified])
  @@index([premium])
  @@index([available])
  @@index([createdAt])
}

model Certification {
  id        String           @id @default(uuid())
  name      String
  code      String           @unique
  artisans  ArtisanCompany[]
}

model Specialty {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  artisans  ArtisanCompany[]
  leads     Lead[]
}

model Lead {
  id              String          @id @default(uuid())
  firstName       String
  lastName        String
  email           String
  phone           String
  zipCode         String
  city            String?
  department      String
  projectType     String
  description     String?
  budget          String?
  status          LeadStatus      @default(NEW)
  score           Float?
  notes           String?
  source          String          @default("Formulaire devis")
  campaign        String          @default("Organic")
  country         String          @default("France")
  artisanId       String?
  specialtyId     String?
  artisan         ArtisanCompany? @relation(fields: [artisanId], references: [id])
  specialty       Specialty?      @relation(fields: [specialtyId], references: [id])
  quotes          Quote[]
  project         Project?
  assignments     LeadAssignment[]
  contactAttempts ContactAttempt[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([status])
  @@index([artisanId])
  @@index([createdAt])
  @@index([campaign])
}

model Article {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  image       String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  author      String?
  authorRole  String?
  readTime    Int       @default(5)
  tags        Json?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([published])
  @@index([featured])
  @@index([categoryId])
  @@index([createdAt])
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  articles Article[]
}

model Department {
  id      String @id @default(uuid())
  code    String @unique
  name    String
  region  String
  density Float?
}

model Review {
  id        String         @id @default(uuid())
  rating    Int
  comment   String?
  author    String?
  avatar    String?
  date      String?
  project   String?
  userId    String?
  artisanId String
  artisan   ArtisanCompany @relation(fields: [artisanId], references: [id])
  user      User?          @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())

  @@index([artisanId])
  @@index([rating])
  @@index([userId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([read])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Subscription {
  id        String         @id @default(uuid())
  artisanId String         @unique
  plan      String
  status    String
  expiresAt DateTime?
  artisan   ArtisanCompany @relation(fields: [artisanId], references: [id])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

// ==================== NEW MODELS ====================

model Quote {
  id           String          @id @default(uuid())
  leadId       String
  artisanId    String
  status       QuoteStatus     @default(DRAFT)
  totalHT      Float           @default(0)
  totalTTC     Float           @default(0)
  tvaRate      Float           @default(0.20)
  validityDays Int             @default(30)
  notes        String?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lead         Lead            @relation(fields: [leadId], references: [id])
  artisan      ArtisanCompany  @relation(fields: [artisanId], references: [id])
  lineItems    QuoteLineItem[]
}

model QuoteLineItem {
  id          String   @id @default(uuid())
  quoteId     String
  designation String
  quantity    Float    @default(1)
  unitPrice   Float
  total       Float
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(uuid())
  leadId      String        @unique
  ownerId     String
  artisanId   String
  status      ProjectStatus @default(QUOTE_REQUESTED)
  startDate   DateTime?
  endDate     DateTime?
  finalPrice  Float?
  rating      Int?
  review      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lead        Lead          @relation(fields: [leadId], references: [id])
  owner       User          @relation(fields: [ownerId], references: [id])
  artisan     ArtisanCompany @relation(fields: [artisanId], references: [id])
  documents   Document[]
}

model Document {
  id        String       @id @default(uuid())
  projectId String?
  artisanId String?
  userId    String?
  type      DocumentType
  name      String
  url       String
  size      Int?
  mimeType  String?
  createdAt DateTime     @default(now())
  project   Project?     @relation(fields: [projectId], references: [id])
  user      User?        @relation(fields: [userId], references: [id])
}

model Payment {
  id              String   @id @default(uuid())
  stripePaymentId String   @unique
  userId          String
  amount          Float
  currency        String   @default("EUR")
  status          String
  description     String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model Favorite {
  id        String         @id @default(uuid())
  userId    String
  artisanId String
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  artisan   ArtisanCompany @relation(fields: [artisanId], references: [id])

  @@unique([userId, artisanId])
}

model LeadAssignment {
  id         String   @id @default(uuid())
  leadId     String
  artisanId  String
  assignedAt DateTime @default(now())
  accepted   Boolean?
  acceptedAt DateTime?
  reason     String?
  lead       Lead     @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([artisanId])
}

model ContactAttempt {
  id        String   @id @default(uuid())
  leadId    String
  artisanId String
  type      String // CALL, EMAIL, VISIT, SMS
  notes     String?
  outcome   String? // ANSWERED, NO_ANSWER, MEETING_SCHEDULED
  createdAt DateTime @default(now())
  artisan   ArtisanCompany @relation(fields: [artisanId], references: [id])
  lead      Lead     @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([artisanId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
