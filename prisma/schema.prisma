generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  role                Role              @default(USER)
  status              String            @default("active")
  source              String            @default("Direct")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  onboardingCompleted Boolean           @default(false)
  artisan             ArtisanCompany?
  receivedMessages    Message[]         @relation("ReceivedMessages")
  sentMessages        Message[]         @relation("SentMessages")
  notifications       Notification[]
  profile             Profile?
  projectDocuments    ProjectDocument[]
}

model Profile {
  id        String  @id @default(uuid())
  userId    String  @unique
  firstName String?
  lastName  String?
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  user      User    @relation(fields: [userId], references: [id])
}

model ArtisanCompany {
  id                String          @id @default(uuid())
  userId            String          @unique
  slug              String          @unique
  name              String
  siret             String          @unique
  description       String?
  address           String
  city              String
  zipCode           String
  department        String
  region            String?
  latitude          Float?
  longitude         Float?
  phone             String?
  email             String?
  website           String?
  avatar            String?
  logoUrl           String?
  isFeatured        Boolean         @default(false)
  verified          Boolean         @default(false)
  premium           Boolean         @default(false)
  available         Boolean         @default(true)
  rating            Float           @default(0)
  reviewCount       Int             @default(0)
  projectCount      Int             @default(0)
  yearsExperience   Int             @default(0)
  responseTime      String?
  since             Int?
  gallery           Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  credits           Int             @default(0)
  certificationDocs Json?
  googleBusinessUrl String?
  articles          Article[]
  user              User            @relation(fields: [userId], references: [id])
  receivedLeads     Lead[]          @relation("LeadArtisan")
  purchasedLeads    Lead[]          @relation("LeadPurchaser")
  leadPurchases     LeadPurchase[]
  quotes            Quote[]
  reviews           Review[]
  subscription      Subscription?
  certifications    Certification[] @relation("ArtisanCompanyToCertification")
  specialties       Specialty[]     @relation("ArtisanCompanyToSpecialty")
}

model Certification {
  id       String           @id @default(uuid())
  name     String
  code     String           @unique
  artisans ArtisanCompany[] @relation("ArtisanCompanyToCertification")
}

model Specialty {
  id       String           @id @default(uuid())
  name     String
  slug     String           @unique
  leads    Lead[]
  artisans ArtisanCompany[] @relation("ArtisanCompanyToSpecialty")
}

model Lead {
  id                 String          @id @default(uuid())
  firstName          String
  lastName           String
  email              String
  phone              String
  zipCode            String
  city               String?
  department         String
  projectType        String
  description        String?
  budget             String?
  status             LeadStatus      @default(NEW)
  score              Float?
  source             String          @default("Formulaire devis")
  campaign           String          @default("Organic")
  country            String          @default("France")
  artisanId          String?
  specialtyId        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  isContactRequested Boolean         @default(false)
  price              Int             @default(2000)
  purchasedById      String?
  temperature        LeadTemperature @default(COLD)
  artisan            ArtisanCompany? @relation("LeadArtisan", fields: [artisanId], references: [id])
  purchasedBy        ArtisanCompany? @relation("LeadPurchaser", fields: [purchasedById], references: [id])
  specialty          Specialty?      @relation(fields: [specialtyId], references: [id])
  purchases          LeadPurchase[]
  quotes             Quote[]
}

model Article {
  id         String          @id @default(uuid())
  title      String
  slug       String          @unique
  content    String
  excerpt    String?
  image      String?
  published  Boolean         @default(false)
  featured   Boolean         @default(false)
  authorRole String?
  readTime   Int             @default(5)
  tags       Json?
  categoryId String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  authorId   String?
  author     ArtisanCompany? @relation(fields: [authorId], references: [id])
  category   Category?       @relation(fields: [categoryId], references: [id])
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  articles Article[]
}

model Department {
  id      String @id @default(uuid())
  code    String @unique
  name    String
  region  String
  density Float?
}

model Review {
  id        String         @id @default(uuid())
  rating    Int
  comment   String?
  author    String?
  avatar    String?
  date      String?
  project   String?
  artisanId String
  createdAt DateTime       @default(now())
  artisan   ArtisanCompany @relation(fields: [artisanId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([receiverId, read])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, read])
}

model OutreachCampaign {
  id        String            @id @default(uuid())
  name      String
  subject   String
  body      String
  createdAt DateTime          @default(now())
  contacts  OutreachContact[]
}

model OutreachContact {
  id         String           @id @default(uuid())
  email      String
  campaignId String
  status     String           @default("PENDING")
  campaign   OutreachCampaign @relation(fields: [campaignId], references: [id])
}

model Subscription {
  id               String         @id @default(uuid())
  artisanId        String         @unique
  plan             String         @default("basic")
  status           String         @default("active")
  expiresAt        DateTime?
  articlesQuota    Int            @default(1)
  createdAt        DateTime       @default(now())
  leadQuotaMonthly Int            @default(0)
  priceMonthly     Int            @default(1999)
  updatedAt        DateTime       @updatedAt
  artisan          ArtisanCompany @relation(fields: [artisanId], references: [id])
}

model LeadPurchase {
  id        String         @id @default(uuid())
  leadId    String
  artisanId String
  price     Int
  createdAt DateTime       @default(now())
  artisan   ArtisanCompany @relation(fields: [artisanId], references: [id])
  lead      Lead           @relation(fields: [leadId], references: [id])
}

model KPI {
  id    String   @id @default(uuid())
  name  String
  value Float
  date  DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model ProjectDocument {
  id        String   @id @default(uuid())
  userId    String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Quote {
  id           String         @id @default(uuid())
  leadId       String?
  artisanId    String
  amount       Int
  description  String
  validityDate DateTime
  status       QuoteStatus    @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  artisan      ArtisanCompany @relation(fields: [artisanId], references: [id])
  lead         Lead?          @relation(fields: [leadId], references: [id])

  @@index([artisanId, createdAt])
  @@index([leadId])
  @@index([status])
}

enum Role {
  USER
  ARTISAN
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  REJECTED
}

enum LeadTemperature {
  COLD
  HOT
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}
